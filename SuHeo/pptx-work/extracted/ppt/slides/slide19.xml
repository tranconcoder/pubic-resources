:ln w="9525"><a:solidFill><a:srgbClr val="CCCCCC"/></a:solidFill></a:ln></p:spPr></p:pic><p:sp><p:nvSpPr><p:cNvPr id="45" name="BodyBox"/><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="4400000" y="4100000"/><a:ext cx="3800000" cy="2600000"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr wrap="square"/><a:lstStyle/><a:p><a:pPr marL="171450" indent="-171450"><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="B88C00"/></a:solidFill></a:rPr><a:t>Cấu tạo: </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>động cơ 30–60HP + rổ nghiền inox 304 chứa bi nghiền (sứ/thủy tinh) + hệ nâng hạ thủy lực.</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="B88C00"/></a:solidFill></a:rPr><a:t>Nguyên lý: </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>lực va đập + ma sát + cắt giữa bi nghiền và paste → giảm kích thước hạt xuống 10–20 µm.</a:t></a:r></a:p></p:txBody></p:sp><p:sp><p:nvSpPr><p:cNvPr id="46" name="TitleBox"/><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="8300000" y="1550000"/><a:ext cx="3800000" cy="400000"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr/><a:lstStyle/><a:p><a:r><a:rPr lang="vi-VN" sz="1900" b="1" dirty="0"><a:solidFill><a:srgbClr val="B88C00"/></a:solidFill></a:rPr><a:t>Máy pha loãng (PL01-03)</a:t></a:r></a:p></p:txBody></p:sp><p:pic><p:nvPicPr><p:cNvPr id="47" name="EquipPhoto"/><p:cNvPicPr><a:picLocks noChangeAspect="1"/></p:cNvPicPr><p:nvPr/></p:nvPicPr><p:blipFill><a:blip r:embed="rId4"/><a:stretch><a:fillRect/></a:stretch></p:blipFill><p:spPr><a:xfrm><a:off x="8931750" y="2050000"/><a:ext cx="2536500" cy="1900000"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:ln w="9525"><a:solidFill><a:srgbClr val="CCCCCC"/></a:solidFill></a:ln></p:spPr></p:pic><p:sp><p:nvSpPr><p:cNvPr id="48" name="BodyBox"/><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="8300000" y="4100000"/><a:ext cx="3800000" cy="2600000"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></p:spPr><p:txBody><a:bodyPr wrap="square"/><a:lstStyle/><a:p><a:pPr marL="171450" indent="-171450"><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="B88C00"/></a:solidFill></a:rPr><a:t>Cấu tạo: </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>bồn chứa inox + cánh khuấy thủy lực 4 cánh đối xứng (dòng chảy hướng trục) + van xả đáy côn.</a:t></a:r></a:p><a:p><a:pPr marL="171450" indent="-171450"><a:buChar char="•"/></a:pPr><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="B88C00"/></a:solidFill></a:rPr><a:t>Nguyên lý: </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>khuấy trộn tạo dòng đối lưu tuần hoàn → chỉnh độ nhớt/tỷ trọng bằng dung môi &amp; phụ gia bổ sung.</a:t></a:r></a:p></p:txBody></p:sp></p:spTree><p:extLst><p:ext uri="{BB962C8B-B14F-4D97-AF65-F5344CB8AC3E}"><p14:creationId xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" val="2565424021"/></p:ext></p:extLst></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>