/p:spPr><p:style><a:lnRef idx="2"><a:schemeClr val="accent1"/></a:lnRef><a:fillRef idx="0"><a:schemeClr val="accent1"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent1"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="tx1"/></a:fontRef></p:style></p:cxnSp><p:cxnSp><p:nvCxnSpPr><p:cNvPr id="39" name="Straight Connector 33"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{8BD1B811-1F9A-72A2-5D48-C738A3D8E384}"/></a:ext></a:extLst></p:cNvPr><p:cNvCxnSpPr/><p:nvPr/></p:nvCxnSpPr><p:spPr><a:xfrm><a:off x="1190604" y="1295400"/><a:ext cx="9616733" cy="0"/></a:xfrm><a:prstGeom prst="line"><a:avLst/></a:prstGeom><a:ln><a:solidFill><a:schemeClr val="bg1"/></a:solidFill></a:ln><a:effectLst><a:glow rad="63500"><a:schemeClr val="accent5"><a:satMod val="175000"/><a:alpha val="40000"/></a:schemeClr></a:glow></a:effectLst></p:spPr><p:style><a:lnRef idx="2"><a:schemeClr val="accent1"/></a:lnRef><a:fillRef idx="0"><a:schemeClr val="accent1"/></a:fillRef><a:effectRef idx="1"><a:schemeClr val="accent1"/></a:effectRef><a:fontRef idx="minor"><a:schemeClr val="tx1"/></a:fontRef></p:style></p:cxnSp><p:sp><p:nvSpPr><p:cNvPr id="3" name="TextBox 2"><a:extLst><a:ext uri="{FF2B5EF4-FFF2-40B4-BE49-F238E27FC236}"><a16:creationId xmlns:a16="http://schemas.microsoft.com/office/drawing/2014/main" id="{BD76977D-DEA0-6767-C60C-EF3E039FBF42}"/></a:ext></a:extLst></p:cNvPr><p:cNvSpPr txBox="1"/><p:nvPr/></p:nvSpPr><p:spPr><a:xfrm><a:off x="685800" y="1550000"/><a:ext cx="11020400" cy="4900600"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom><a:noFill/></p:spPr><p:txBody><a:bodyPr wrap="square" rtlCol="0"><a:spAutoFit/></a:bodyPr><a:lstStyle/><a:p><a:pPr marL="0" indent="0"/><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="0000FF"/></a:solidFill></a:rPr><a:t>Bước 1. Định lượng — </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>cân đúng tỷ lệ nhựa/dung môi/phụ gia/bột màu — sai số ở đây kéo lệch tỷ trọng &amp; độ nhớt về sau, KHÔNG thể bỏ qua.</a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" i="1" dirty="0"><a:solidFill><a:srgbClr val="808080"/></a:solidFill></a:rPr><a:t>  (theo công thức R&amp;D)</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"/><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="0000FF"/></a:solidFill></a:rPr><a:t>Bước 2. Đánh paste (phân tán) — </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>khuấy phân tán tốc độ cao 900–1200 vòng/phút để hòa trộn bột màu/độn vào nhựa — bắt buộc trước khi nghiền vì hạt còn thô.</a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" i="1" dirty="0"><a:solidFill><a:srgbClr val="808080"/></a:solidFill></a:rPr><a:t>  (~vài chục phút/mẻ)</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"/><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="0000FF"/></a:solidFill></a:rPr><a:t>Bước 3. Nghiền mịn — </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>dùng bi nghiền tạo lực va đập đưa hạt xuống 10–20 µm — CÓ THỂ BỎ QUA nếu mẻ đã đạt độ mịn ở bước đánh paste (kiểm tra Hegman trước khi quyết định).</a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" i="1" dirty="0"><a:solidFill><a:srgbClr val="808080"/></a:solidFill></a:rPr><a:t>  (đến khi đạt độ mịn chuẩn)</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"/><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="0000FF"/></a:solidFill></a:rPr><a:t>Bước 4. Ngâm ủ — </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>giữ yên để hệ ổn định, giảm bọt khí — cần thiết cho sơn cao cấp (Epoxy/PU), có thể rút ngắn với sơn Alkyd thường.</a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" i="1" dirty="0"><a:solidFill><a:srgbClr val="808080"/></a:solidFill></a:rPr><a:t>  (vài giờ tùy loại sơn)</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"/><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="0000FF"/></a:solidFill></a:rPr><a:t>Bước 5. Pha loãng — </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>bổ sung dung môi/phụ gia còn lại, chỉnh độ nhớt về đúng thông số kỹ thuật (KU) — bắt buộc, quyết định độ phủ cuối cùng.</a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" i="1" dirty="0"><a:solidFill><a:srgbClr val="808080"/></a:solidFill></a:rPr><a:t>  (đến khi đạt độ nhớt mục tiêu)</a:t></a:r></a:p><a:p><a:pPr marL="0" indent="0"/><a:r><a:rPr lang="vi-VN" sz="1800" b="1" dirty="0"><a:solidFill><a:srgbClr val="0000FF"/></a:solidFill></a:rPr><a:t>Bước 6. Lọc &amp; đóng gói — </a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" dirty="0"/><a:t>loại tạp chất/hạt vón trước khi xuất xưởng — bắt buộc với mọi lô hàng.</a:t></a:r><a:r><a:rPr lang="vi-VN" sz="1800" i="1" dirty="0"><a:solidFill><a:srgbClr val="808080"/></a:solidFill></a:rPr><a:t>  (bước cuối, không thể bỏ qua)</a:t></a:r></a:p></p:txBody></p:sp></p:spTree><p:extLst><p:ext uri="{BB962C8B-B14F-4D97-AF65-F5344CB8AC3E}"><p14:creationId xmlns:p14="http://schemas.microsoft.com/office/powerpoint/2010/main" val="718888953"/></p:ext></p:extLst></p:cSld><p:clrMapOvr><a:masterClrMapping/></p:clrMapOvr></p:sld>